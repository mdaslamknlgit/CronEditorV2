@page "/cron-schedule"
@rendermode InteractiveServer
@inject CronBuilderService CronService

<PageTitle>Cron Schedule Manager</PageTitle>

<div class="d-flex justify-content-between align-items-center mb-3">
    <h1>Cron Schedule Manager</h1>
    <button class="btn btn-primary" @onclick="OpenAddModal">
        <span class="bi bi-plus-circle me-1"></span> Add New Schedule
    </button>
</div>

@if (!string.IsNullOrEmpty(statusMessage))
{
    <div class="alert @statusAlertClass alert-dismissible fade show" role="alert">
        @statusMessage
        <button type="button" class="btn-close" @onclick="() => statusMessage = string.Empty"></button>
    </div>
}

@if (schedules.Count == 0)
{
    <div class="text-center py-5">
        <div class="text-muted">
            <span class="bi bi-clock" style="font-size: 3rem;"></span>
            <h4 class="mt-3">No schedules yet</h4>
            <p>Click <strong>Add New Schedule</strong> to create your first cron schedule.</p>
        </div>
    </div>
}
else
{
    <div class="table-responsive">
        <table class="table table-striped table-hover align-middle">
            <thead class="table-dark">
                <tr>
                    <th>Name</th>
                    <th>Expression</th>
                    <th>Description</th>
                    <th>Status</th>
                    <th>Created At</th>
                    <th class="text-center">Actions</th>
                </tr>
            </thead>
            <tbody>
                @foreach (var schedule in schedules)
                {
                    <tr>
                        <td><strong>@schedule.Name</strong></td>
                        <td><code class="bg-light px-2 py-1 rounded">@schedule.Expression</code></td>
                        <td class="text-muted small">@schedule.Description</td>
                        <td>
                            @if (schedule.IsActive)
                            {
                                <span class="badge bg-success">Active</span>
                            }
                            else
                            {
                                <span class="badge bg-secondary">Inactive</span>
                            }
                        </td>
                        <td class="small text-muted">@schedule.CreatedAt.ToLocalTime().ToString("yyyy-MM-dd HH:mm")</td>
                        <td class="text-center">
                            <div class="btn-group btn-group-sm">
                                <button class="btn btn-outline-primary" title="Edit with Visual Builder"
                                        @onclick="() => OpenEditModal(schedule)">
                                    <span class="bi bi-pencil"></span> Edit
                                </button>
                                <button class="btn btn-outline-info" title="Edit Expression Directly"
                                        @onclick="() => OpenExpressionEditor(schedule)">
                                    <span class="bi bi-code-slash"></span> Expr
                                </button>
                                <button class="btn btn-outline-@(schedule.IsActive ? "warning" : "success")"
                                        title="@(schedule.IsActive ? "Deactivate" : "Activate")"
                                        @onclick="() => ToggleActive(schedule)">
                                    <span class="bi bi-@(schedule.IsActive ? "pause" : "play")"></span>
                                </button>
                                <button class="btn btn-outline-danger" title="Delete"
                                        @onclick="() => ConfirmDelete(schedule)">
                                    <span class="bi bi-trash"></span>
                                </button>
                            </div>
                        </td>
                    </tr>
                }
            </tbody>
        </table>
    </div>
}

@if (showDeleteConfirm && scheduleToDelete is not null)
{
    <div class="modal-backdrop-custom">
        <div class="modal-dialog-custom card shadow-lg p-4" style="max-width:420px; margin: auto;">
            <h5 class="text-danger mb-3"><span class="bi bi-exclamation-triangle me-2"></span>Confirm Delete</h5>
            <p>Are you sure you want to delete the schedule <strong>@scheduleToDelete.Name</strong>?</p>
            <p class="text-muted small">Expression: <code>@scheduleToDelete.Expression</code></p>
            <div class="d-flex gap-2 justify-content-end">
                <button class="btn btn-secondary" @onclick="CancelDelete">Cancel</button>
                <button class="btn btn-danger" @onclick="ExecuteDelete">Delete</button>
            </div>
        </div>
    </div>
}

<CronBuilderModal @ref="cronBuilderModal"
                  OnSave="HandleBuilderSave"
                  OnCancel="HandleModalCancel" />

<CronExpressEditorModal @ref="cronExprEditorModal"
                        OnSave="HandleExprEditorSave"
                        OnCancel="HandleModalCancel" />

@code {
    private List<CronScheduleItem> schedules = new();
    private CronBuilderModal? cronBuilderModal;
    private CronExpressEditorModal? cronExprEditorModal;

    private bool showDeleteConfirm = false;
    private CronScheduleItem? scheduleToDelete;

    private string statusMessage = string.Empty;
    private string statusAlertClass = "alert-success";

    private bool isEditing = false;

    protected override void OnInitialized()
    {
        LoadSchedules();
    }

    private void LoadSchedules()
    {
        schedules = CronService.GetSchedules();
    }

    private void OpenAddModal()
    {
        isEditing = false;
        cronBuilderModal?.Show(null);
    }

    private void OpenEditModal(CronScheduleItem item)
    {
        isEditing = true;
        cronBuilderModal?.Show(item);
    }

    private void OpenExpressionEditor(CronScheduleItem item)
    {
        cronExprEditorModal?.Show(item);
    }

    private void HandleBuilderSave(CronScheduleItem item)
    {
        if (isEditing)
        {
            CronService.UpdateSchedule(item);
            ShowStatus("Schedule updated successfully.", "alert-success");
        }
        else
        {
            CronService.AddSchedule(item);
            ShowStatus("Schedule added successfully.", "alert-success");
        }
        LoadSchedules();
    }

    private void HandleExprEditorSave(CronScheduleItem item)
    {
        CronService.UpdateSchedule(item);
        ShowStatus("Expression updated successfully.", "alert-success");
        LoadSchedules();
    }

    private void HandleModalCancel()
    {
        // nothing extra needed
    }

    private void ToggleActive(CronScheduleItem item)
    {
        item.IsActive = !item.IsActive;
        CronService.UpdateSchedule(item);
        ShowStatus($"Schedule '{item.Name}' {(item.IsActive ? "activated" : "deactivated")}.", "alert-info");
        LoadSchedules();
    }

    private void ConfirmDelete(CronScheduleItem item)
    {
        scheduleToDelete = item;
        showDeleteConfirm = true;
    }

    private void CancelDelete()
    {
        showDeleteConfirm = false;
        scheduleToDelete = null;
    }

    private void ExecuteDelete()
    {
        if (scheduleToDelete is not null)
        {
            CronService.DeleteSchedule(scheduleToDelete.Id);
            ShowStatus($"Schedule '{scheduleToDelete.Name}' deleted.", "alert-warning");
            scheduleToDelete = null;
        }
        showDeleteConfirm = false;
        LoadSchedules();
    }

    private void ShowStatus(string message, string cssClass)
    {
        statusMessage = message;
        statusAlertClass = cssClass;
    }
}
